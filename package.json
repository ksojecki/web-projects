{
  "name": "@sojecki/platform-source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev:rod-manager": "node ./node_modules/nx/dist/bin/nx.js run @sojecki/rod-manager-api:serve --no-tui",
    "dev:recepturomat": "node ./node_modules/nx/dist/bin/nx.js run @sojecki/recepturomat-api:serve --no-tui",
    "generate:project": "npx nx g ./tools/generators.json:project-template",
    "lint": "node ./node_modules/nx/dist/bin/nx.js run-many -t lint --no-tui",
    "typecheck": "node ./node_modules/nx/dist/bin/nx.js run-many -t typecheck --no-tui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "node ./scripts/postinstall.mjs",
    "setup:certs": "node ./scripts/setup-dev-certs.mjs"
  },
  "private": true,
  "workspaces": [
    "projects/*/apps/*",
    "libs/*",
    "projects/*/plugins/*/*"
  ],
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-react": "8.0.1",
    "@nx/js": "23.0.0",
    "@nx/node": "23.0.0",
    "@nx/react": "23.0.0",
    "@nx/vite": "23.0.0",
    "@nx/vitest": "23.0.0",
    "@nx/web": "23.0.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.41",
    "@swc/helpers": "0.5.23",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "ajv": "8.20.0",
    "autoprefixer": "10.5.0",
    "daisyui": "5.5.23",
    "husky": "9.1.7",
    "i18next": "26.3.1",
    "jiti": "2.4.2",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.7",
    "mkcert-cli": "1.5.0",
    "nx": "23.0.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "prettier": "3.8.4",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "verdaccio": "6.7.2",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@fastify/autoload": "6.3.1",
    "@fastify/middie": "9.3.2",
    "@fastify/sensible": "6.0.4",
    "@fastify/static": "9.1.3",
    "@tailwindcss/vite": "4.3.1",
    "better-sqlite3": "12.11.1",
    "fastify": "5.8.5",
    "fastify-plugin": "5.1.0",
    "isbot": "5.1.43",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "react-i18next": "17.0.8",
    "react-icons": "5.6.0",
    "react-router": "8.0.1",
    "tailwindcss": "4.3.1"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
