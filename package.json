{
  "name": "@rod-manager/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "lint": "node ./node_modules/nx/bin/nx.js run-many -t lint --no-tui",
    "typecheck": "node ./node_modules/nx/bin/nx.js run-many -t typecheck --no-tui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "node ./scripts/postinstall.mjs",
    "setup:certs": "node ./scripts/setup-dev-certs.mjs",
    "dev:ssr": "node ./node_modules/nx/bin/nx.js run @rod-manager/source:dev:ssr --no-tui",
    "dev:web": "npx nx dev web --no-tui",
    "dev:api": "npx nx serve api --no-tui",
    "build:ssr": "npm run build:web && npm run build:api",
    "build:web": "npx nx run web:build --no-tui && npx nx run web:build-server --no-tui",
    "build:api": "npx nx build api --no-tui",
    "start:ssr": "NODE_ENV=production node dist/apps/api/main.js"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*",
    "libs/plugins/pages/*"
  ],
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-react": "7.28.5",
    "@nx/esbuild": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/node": "22.7.5",
    "@nx/react": "22.7.5",
    "@nx/vite": "22.7.5",
    "@nx/vitest": "22.7.5",
    "@nx/web": "22.7.5",
    "@react-router/dev": "7.14.1",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.0",
    "@swc/core": "1.15.18",
    "@swc/helpers": "0.5.19",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.13.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "4.1.0",
    "ajv": "8.18.0",
    "autoprefixer": "10.4.27",
    "daisyui": "5.5.23",
    "esbuild": "0.28.0",
    "husky": "9.1.7",
    "i18next": "26.3.1",
    "jiti": "2.4.2",
    "jsdom": "22.1.0",
    "lint-staged": "17.0.7",
    "mkcert-cli": "1.5.0",
    "nx": "22.7.5",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "prettier": "3.6.2",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "verdaccio": "6.7.2",
    "vite": "8.0.16",
    "vitest": "4.1.0"
  },
  "dependencies": {
    "@fastify/autoload": "6.0.3",
    "@fastify/middie": "9.3.2",
    "@fastify/sensible": "6.0.4",
    "@fastify/static": "8.3.0",
    "@react-router/node": "7.14.1",
    "@react-router/serve": "7.14.1",
    "@tailwindcss/vite": "4.2.2",
    "better-sqlite3": "12.11.1",
    "fastify": "5.8.3",
    "fastify-plugin": "5.0.1",
    "isbot": "4.4.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.71.2",
    "react-i18next": "17.0.3",
    "react-icons": "5.6.0",
    "react-router": "7.14.1",
    "tailwindcss": "4.2.1"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      },
      "dev:ssr": {
        "executor": "nx:run-commands",
        "options": {
          "parallel": true,
          "commands": [
            "node ./node_modules/nx/bin/nx.js dev web --no-tui",
            "node ./node_modules/nx/bin/nx.js serve api --no-tui"
          ]
        }
      }
    }
  }
}
