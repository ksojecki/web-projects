{
  "name": "@sojecki/platform-server-platform",
  "version": "0.0.1",
  "main": "../../dist/libs/server-platform/index.js",
  "types": "../../dist/libs/server-platform/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@sojecki/platform-source": "./src/index.ts",
      "types": "../../dist/libs/server-platform/index.d.ts",
      "require": "../../dist/libs/server-platform/index.js",
      "default": "../../dist/libs/server-platform/index.js"
    }
  },
  "files": [
    "../../dist/libs/server-platform",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/middie": "^9.3.2",
    "@fastify/sensible": "^6.0.2",
    "@fastify/static": "^9.1.3",
    "@sojecki/platform-shared": "0.0.1",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0"
  },
  "nx": {
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "libs/server-platform",
          "command": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.lib.json && node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.spec.json"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node node_modules/oxlint/bin/oxlint libs/server-platform --config .oxlintrc.json"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "outputs": [
          "{workspaceRoot}/dist/libs/server-platform"
        ],
        "options": {
          "cwd": "libs/server-platform",
          "command": "node ../../node_modules/typescript/bin/tsc --build tsconfig.lib.json"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "libs/server-platform",
          "command": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.mts"
        }
      }
    }
  }
}
