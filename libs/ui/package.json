{
  "name": "@sojecki/platform-ui",
  "version": "0.0.1",
  "type": "module",
  "main": "../../dist/libs/ui/index.js",
  "module": "../../dist/libs/ui/index.js",
  "types": "../../dist/libs/ui/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@sojecki/platform-source": "./src/index.ts",
      "types": "../../dist/libs/ui/index.d.ts",
      "import": "../../dist/libs/ui/index.js",
      "default": "../../dist/libs/ui/index.js"
    }
  },
  "files": [
    "../../dist/libs/ui",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "targets": {
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node node_modules/oxlint/bin/oxlint libs/ui --config .oxlintrc.json"
        }
      },
      "format": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "libs/ui",
          "command": "node ../../node_modules/prettier/bin/prettier.cjs --write ."
        }
      }
    }
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
