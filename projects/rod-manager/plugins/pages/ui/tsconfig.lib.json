{
  "extends": "../../../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "../../../../../dist/projects/rod-manager/plugins/pages/ui",
    "tsBuildInfoFile": "../../../../../dist/projects/rod-manager/plugins/pages/ui/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "paths": {
      "@ksojecki/platform-shared": ["../../../../../libs/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "references": [
    {
      "path": "../../../../../libs/shared/tsconfig.lib.json"
    }
  ]
}
